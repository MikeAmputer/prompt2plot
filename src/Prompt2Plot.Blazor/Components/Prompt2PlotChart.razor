@using System.Text.Json
@using Prompt2Plot.Contracts.Visualization

@inject IPlotComponentRegistry ComponentRegistry

@if (_innerComponent is null || _parameters is null)
{
	<div class="alert alert-warning">
		No renderer registered for chart type: @Data.ChartType
	</div>
}
else
{
	<DynamicComponent Type="_innerComponent" Parameters="_parameters"/>
}

@code {

	[Parameter, EditorRequired] public PlotData Data { get; set; } = null!;

	private Type? _innerComponent;

	private Dictionary<string, object>? _parameters;

	protected override void OnParametersSet()
	{
		var innerComponentDescriptor = ComponentRegistry.Resolve(Data.ChartType, Data.WorkflowKey);

		if (innerComponentDescriptor == null)
		{
			_innerComponent = null;
			_parameters = null;

			return;
		}

		_innerComponent = innerComponentDescriptor.ComponentType;

		foreach (var dataset in Data.Datasets)
		{
			NormalizeDataset(dataset);
		}

		_parameters ??= new Dictionary<string, object>(1);

		_parameters["Data"] = Data;

		if (innerComponentDescriptor.Settings != null)
		{
			_parameters["Settings"] = innerComponentDescriptor.Settings;
		}
	}

	private void NormalizeDataset(PlotDataset dataset)
	{
		foreach (var row in dataset.Rows)
		{
			for (var i = 0; i < row.Length; i++)
			{
				row[i] = NormalizeValue(row[i]);
			}
		}
	}

	private static object? NormalizeValue(object? value)
	{
		if (value is not JsonElement je)
		{
			return value;
		}

		return je.ValueKind switch
		{
			JsonValueKind.Number =>
				je.TryGetInt64(out var l) ? l :
				je.TryGetDecimal(out var d) ? d :
				je.GetDouble(),

			JsonValueKind.String =>
				DateTime.TryParse(je.GetString(), out var dt)
					? dt
					: je.GetString(),

			JsonValueKind.True => true,
			JsonValueKind.False => false,

			JsonValueKind.Null => null,

			JsonValueKind.Array => je.EnumerateArray()
				.Select(x => NormalizeValue(x))
				.ToArray(),

			JsonValueKind.Object => je.ToString(),

			_ => je.ToString()
		};
	}

}