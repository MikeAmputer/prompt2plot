@page "/plots"
@rendermode InteractiveServer

@using System.Text.Json
@using BlazorDemo.Services
@using Prompt2Plot.Contracts;
@using Prompt2Plot.InMemory
@using Prompt2Plot.Contracts.Visualization
@using Prompt2Plot.Blazor.Components

@inject InMemoryWorkItemRepository Repository
@inject PromptExecutorController PromptController

<PageTitle>Plot Builder</PageTitle>

<h1>Plot Builder</h1>

<div class="mb-3">
	<label class="form-label">Prompt</label>

	<textarea class="form-control"
	          rows="4"
	          @bind="_prompt"
	          @bind:event="oninput"
	          disabled="@_isProcessing">
    </textarea>
</div>

<button class="btn btn-primary"
        @onclick="BuildPlot"
        disabled="@IsBuildDisabled">
	Build Plot
</button>

@if (_isProcessing)
{
	<p class="mt-3"><em>Processing...</em></p>
}

@if (_plotData != null)
{
	<div class="mt-4">
		<h4>Chart</h4>

		<Prompt2PlotChart @key="_plotData" Data="_plotData"/>
	</div>
}

@if (_resultJson != null)
{
	<div class="mt-4">
		<details>
			<summary><strong>Result dataset JSON</strong></summary>

			<pre style="max-height:400px;overflow:auto;margin-top:10px">@_resultJson</pre>
		</details>
	</div>
}

@code {

	private string? _prompt;
	private bool _isProcessing;
	private string? _resultJson;
	private PlotData? _plotData;

	private bool IsBuildDisabled => _isProcessing || string.IsNullOrWhiteSpace(_prompt);

	private async Task BuildPlot()
	{
		if (string.IsNullOrWhiteSpace(_prompt))
		{
			return;
		}

		_isProcessing = true;
		_resultJson = null;

		try
		{
			var workItem = new WorkItem
			{
				WorkflowKey = PromptController.CurrentFlowKey,
				NaturalLanguageRequest = _prompt
			};

			var id = Repository.AddWorkItem(workItem);

			var result = await Repository.WaitForResultAsync(id, CancellationToken.None);

			var plotData = result.AsPlotData();

			_resultJson = JsonSerializer.Serialize(plotData, new JsonSerializerOptions
			{
				WriteIndented = true
			});

			// _plotData = JsonSerializer.Deserialize<PlotData?>(_resultJson);
			_plotData = plotData;
		}
		finally
		{
			_isProcessing = false;
		}
	}

}